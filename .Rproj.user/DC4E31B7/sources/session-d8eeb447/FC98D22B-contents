%%  ~~further notes~~
%}

\seealso{
\code{\link{areg}, \link{cv.alfareg}
}
}

\examples{
data(fadn)
coords <- fadn[, 1:2]
y <- fadn[, 3:7]
x <- fadn[, 8, drop = FALSE]
mod <- alfa.esf(y, x, a = 0.1, coords = coords)
}


