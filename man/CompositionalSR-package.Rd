\name{CompositionalSR-package}
\alias{CompositionalSR-package}
\docType{package}
\title{
Spatial Regression Models with Compositional Data
}

\description{
Spatial regression models with compositional responses using the \eqn{\alpha}--transformation.
The models included are the \eqn{\alpha}-regression (not spatial), the \eqn{\alpha}-regression
(not spatial) with compositional predictors, the \eqn{\alpha}-spatially lagged X (\eqn{\alpha}-SLX) model,
the geographically weighted \eqn{\alpha}-regression (GW\eqn{\alpha}R) model and the \eqn{\alpha}-eigenvector
spatial filtering (\eqn{\alpha}-ESF) model.
}

